OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
GEMINI_API_KEY=AIza-your-free-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=sk-ant-optional-fallback-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT_SECONDS=45
FLASK_SECRET_KEY=replace-with-a-long-random-secret
FREE_GENERATION_LIMIT=2
GENERATED_RETENTION_DAYS=7
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_STARTER=price_starter_10_generations
STRIPE_PRICE_HUNT=price_hunt_40_generations
STRIPE_PRICE_SPRINT=price_sprint_150_generations

# ---- Admin dashboard login ----
TAILORBACK_ADMIN_USER=admin
TAILORBACK_ADMIN_PASSWORD=change-me

# ---- Google OAuth (sign in with Google) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email for activation + password-reset links. Without SMTP_HOST the link is only logged. ----
# Example uses Resend: host smtp.resend.com, port 465, SSL on, user "resend", password = API key.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=noreply@tailorback.com   # automated mail "from" address
SMTP_FROM_NAME=TailorBack          # sender display name; Reply-To is set to the support address
SMTP_USE_SSL=1                     # 1 for SMTPS (port 465), else STARTTLS

# ---- Optional: official billing sync (ADMIN keys, not the inference keys above) ----
OPENAI_ADMIN_KEY=                  # sk-admin-... (OpenAI org Admin keys; owner only)
ANTHROPIC_ADMIN_KEY=               # sk-ant-admin-... (Anthropic org owner only)
# Estimated price per 1M tokens (input/output) for the admin cost dashboard
OPENAI_PRICE_IN=0.40
OPENAI_PRICE_OUT=1.60
GEMINI_PRICE_IN=0.10
GEMINI_PRICE_OUT=0.40
CLAUDE_PRICE_IN=3.00
CLAUDE_PRICE_OUT=15.00
