{
  "manifest_version": 3,
  "name": "TailorBack Job Grabber",
  "version": "0.2.0",
  "description": "Capture a job posting from LinkedIn, Indeed, Greenhouse or Lever and tailor your resume with TailorBack.",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite"],
  "action": {
    "default_title": "TailorBack — tailor this job",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
